APP_NAME=quant-project
ENV=dev
TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO

# Paths (relative paths resolve from project root)
PROJECT_ROOT=.
DATA_ROOT=./data
RAW_DATA_ROOT=./data/raw
CURATED_DATA_ROOT=./data/curated
FEATURE_DATA_ROOT=./data/features
LOG_ROOT=./logs
DUCKDB_PATH=./data/tmp/quant.duckdb

# PostgreSQL
POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quant

# Provider credentials (placeholder in scaffold stage)
KRX_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
DART_API_KEY=

# Defaults
DEFAULT_UNIVERSE_NAME=core_equity_etf
DEFAULT_FEATURE_SET_NAME=core_v1
